{
  "name": "blood-bowl-manager",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:bot": "npm run dev --workspace=discord-bot",
    "dev:web": "npm run dev --workspace=web-app",
    "dev:all": "npm-run-all --parallel dev:bot dev:web",
    "db:migrate": "npm run migrate --workspace=database",
    "db:seed": "npm run seed --workspace=database"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  }
}
